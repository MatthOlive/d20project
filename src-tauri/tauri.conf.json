{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "D20 Project",
  "version": "0.2.3",
  "identifier": "com.d20project.desktop",
  "build": {
    "beforeDevCommand": "node node_modules/vite/bin/vite.js dev --host 127.0.0.1 --port 5180",
    "devUrl": "http://127.0.0.1:5180",
    "beforeBuildCommand": "node scripts/build-tauri-frontend.mjs",
    "frontendDist": "../dist/client"
  },
  "app": {
    "windows": [
      {
        "title": "D20 Project",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYxMEE4M0Q0NTg3QUYwNDcKUldSSDhIcFkxSU1LWWMxak1MUWhlREJTTHJwbWNYQ3pDYUhXcHZkYm01dm40WGRPU1NqckVCVGUK",
      "endpoints": [
        "https://github.com/MatthOlive/d20project/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
