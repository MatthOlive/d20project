{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "D20 Project",
  "version": "0.2.0",
  "identifier": "com.d20project.app",
  "build": {
    "beforeDevCommand": "node node_modules/vite/bin/vite.js dev --host 127.0.0.1 --port 5180",
    "devUrl": "http://127.0.0.1:5180",
    "beforeBuildCommand": "node node_modules/vite/bin/vite.js build",
    "frontendDist": "../dist/client"
  },
  "app": {
    "windows": [
      {
        "title": "D20 Project",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"]
  }
}
